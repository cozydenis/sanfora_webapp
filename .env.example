# Site URL (for WhatsApp links and SEO)
# Update this when deploying to production
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin password (server-side only — DO NOT use NEXT_PUBLIC_ prefix!)
ADMIN_PASSWORD=change_me_to_a_strong_password

# Session signing secret (generate a random string, e.g.: openssl rand -hex 32)
ADMIN_SESSION_SECRET=change_me_to_a_random_secret

# Vercel Blob Storage Token (for image uploads)
# BLOB_READ_WRITE_TOKEN=your_token_here

# Database URL (for Neon Postgres)
# DATABASE_URL=postgresql://user:password@host/database?sslmode=require
